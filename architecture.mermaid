graph TD

%% ─────────────────────────────────────────────
%%  EXTERNAL SERVICES
%% ─────────────────────────────────────────────
subgraph EXT["☁️  External Services"]
    GEMINI["Google Gemini AI\ngemini-2.5-flash\nEmbeddings API"]
end

%% ─────────────────────────────────────────────
%%  FRONTEND  (React 19 + Vite + TypeScript)
%% ─────────────────────────────────────────────
subgraph FE["🖥️  Frontend  ·  React 19 + Vite + TypeScript  ·  port 5173"]

    subgraph FE_ENTRY["Entry"]
        INDEX["index.tsx"]
        APP["App.tsx\n(Router · Sidebar · Auth Guard)"]
    end

    subgraph FE_CTX["Global State"]
        AUTH_CTX["AuthContext\n(user, token, login/logout)"]
    end

    subgraph FE_VIEWS["Views / Pages"]
        V_HOME["HomePage\n(Dashboard)"]
        V_BUILD["BuildPersonaPage\n(AI persona creation)"]
        V_CHAT["ChatPage\n(Multi-persona chat)"]
        V_SIM["SimulationPage\n(Scenario testing)"]
        V_GALLERY["GalleryPage\n(My Personas)"]
        V_LIB["PersonaLibraryPage\n(Public / Global)"]
        V_BIZ["BusinessProfilePage"]
        V_ADMIN["AdminPage"]
        V_LOGIN["LoginPage"]
    end

    subgraph FE_COMP["Reusable Components"]
        C_BTN["Button · FormInput\nLoadingSpinner · ErrorMessage"]
        C_BANNER["ApiErrorBanner\n(global error notifications)"]
        C_ICON["IconPicker"]
        C_AGENT["AgentPipelineViewer\n(think · retrieve · respond · validate)"]
        C_SIMFORM["SimulationTemplateForm"]
    end

    subgraph FE_HOOKS["Custom Hooks"]
        H_CHAT["useChatSessions()"]
        H_PERSONA["usePersonas()"]
    end

    subgraph FE_SVC["API Service Layer"]
        SVC_BASE["api.ts\n(base HTTP client · token · errors)"]
        SVC_AUTH["authApi.ts"]
        SVC_PERSONA["personaApi.ts"]
        SVC_CHAT["chatApi.ts"]
        SVC_SIM["simulationApi.ts"]
        SVC_AGENT["agentApi.ts"]
        SVC_BIZ["businessProfileApi.ts"]
        SVC_FG["focusGroupApi.ts"]
        SVC_ADMIN["adminApi.ts"]
        SVC_GEMINI_FE["gemini.ts\n(direct Gemini client)"]
    end

    subgraph FE_UTILS["Utils"]
        U_DATE["dateUtils\n(date formatting)"]
        U_NORM["normalizeData\n(API response normalizer)"]
        U_BIZ["businessProfile\n(profile helpers)"]
        U_NAMES["humanNames\n(name generation)"]
        U_PERSUADE["persuasionScore\n(score calculator)"]
        U_SIMDISP["simulationResponsePlainText\nsurveySimulationDisplay"]
    end
end

%% ─────────────────────────────────────────────
%%  BACKEND  (Express + TypeScript)
%% ─────────────────────────────────────────────
subgraph BE["⚙️  Backend  ·  Express 4 + TypeScript  ·  port 3001"]

    subgraph BE_ENTRY["Entry"]
        BE_IDX["index.ts\n(server bootstrap · route registration)"]
    end

    subgraph BE_MW["Middleware"]
        MW_AUTH["authenticateToken\n(JWT verify · inject userId)"]
        MW_CORS["CORS\n(localhost:3000 / :5173)"]
        MW_BODY["Body Parser\n(JSON · 50 MB limit)"]
        MW_ERR["errorHandler\n(global error responses)"]
    end

    subgraph BE_ROUTES["Routes  →  Controllers"]
        R_AUTH["POST /api/auth/register\nPOST /api/auth/login\n→ authController"]
        R_PERSONA["GET · POST /api/personas\nGET · PUT · DELETE /api/personas/:id\nstar · unstar · files\n→ personaController"]
        R_CHAT["GET · POST /api/chat/sessions\nmessages · personas\n→ chatController"]
        R_AGENT["POST /api/agent/chat\n→ agentController"]
        R_SIM["GET · POST /api/simulations\n→ simulationController"]
        R_BIZ["GET · POST /api/profile/business\n→ businessProfileController"]
        R_FG["GET · POST · PUT · DELETE\n/api/focus-groups\n→ focusGroupController"]
        R_ADMIN["GET /api/admin/users\nGET /api/admin/analytics\n→ adminController"]
        R_HEALTH["GET /health"]
    end

    subgraph BE_PROMPTS["📝  System Prompts Layer"]
        P_AGENT["Agent System Prompt\nPersona description + files\nBusiness profile context\nConversation history\nRAG retrieved chunks"]
        P_SIM["Simulation System Prompt\nMode: web_page · marketing\nsales_pitch · investor_pitch\nPersona personality\nStimulus content"]
        P_TMPL["Simulation Templates\n(custom system_prompt field\nstored in DB per template)"]
    end

    subgraph BE_SVC["Service Layer (Business Logic)"]
        S_AUTH["authService\n(bcrypt · JWT)"]
        S_PERSONA["personaService\n(CRUD · visibility · star)"]
        S_CHAT["chatService\n(sessions · messages)"]
        S_AGENT["agentService\n4-step Agent Pipeline\n① think  ② retrieve\n③ respond  ④ validate"]
        S_EMBED["embeddingService\n(RAG · vector indexing)"]
        S_SIM["simulationService"]
        S_SIMMSG["simulationMessageService"]
        S_BIZ["businessProfileService"]
        S_FG["focusGroupService"]
        S_ADMIN["adminService"]
        S_SIMTMPL["simulationTemplateService"]
    end

    subgraph BE_DB_CFG["DB Config"]
        DB_POOL["database.ts\n(pg Pool · connection string)"]
    end
end

%% ─────────────────────────────────────────────
%%  DATABASE  (PostgreSQL)
%% ─────────────────────────────────────────────
subgraph DB["🗄️  PostgreSQL  ·  port 5432"]
    direction LR

    subgraph DB_AUTH_T["Auth & Users"]
        T_USERS["users\nid · username · email\npassword_hash · is_admin\ncreated_at · updated_at"]
    end

    subgraph DB_PERSONA_T["Persona Domain"]
        T_PERSONAS["personas\nid · user_id · name · type\ndescription · visibility\nmetadata (JSONB)\nlast_embedded_at"]
        T_FILES["persona_files\nid · persona_id · name\ncontent · type"]
    end

    subgraph DB_PROFILE_T["Business"]
        T_BIZ["business_profiles\nid · user_id (UNIQUE)\nmission · vision\nofferings · KPIs\nfunding · 20+ fields"]
    end

    subgraph DB_CHAT_T["Chat Domain"]
        T_SESSIONS["chat_sessions\nid · user_id · name"]
        T_SES_P["chat_session_personas\n(junction)"]
        T_MSGS["messages\nid · session_id · sender_type\npersona_id · content\nthinking · retrieval_summary\nvalidation · pipeline_events (JSON)"]
    end

    subgraph DB_SIM_T["Simulation Domain"]
        T_SIM_SESSIONS["simulation_sessions\nid · user_id · persona_id\npersona_ids (JSONB)\nmode · stimulus_image"]
        T_SIM_TMPL["simulations (templates)\ntitle · icon · system_prompt\nallowed_persona_types\npersona_count_min/max"]
    end

    subgraph DB_FG_T["Focus Groups"]
        T_FG["focus_groups\nid · user_id · name"]
        T_FGP["focus_group_personas\n(junction)"]
    end
end

